# Optional private room key. Set this on Render if the room should not be public.
ROOM_KEY="change-me"

# Render injects PORT automatically. Locally the server falls back to 3000.
PORT=3000

# Comma-separated list. Leave empty for same-service Render hosting.
ALLOWED_ORIGINS=""

# Small friend-group defaults.
MAX_USERS=10
MAX_MESSAGES_HISTORY=100
MESSAGE_RATE_LIMIT_MS=650
